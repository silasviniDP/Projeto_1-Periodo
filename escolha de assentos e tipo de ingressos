#include <stdio.h>
#include <locale.h>

#define FILEIRAS  6
#define COLUNAS   8

/* Tipos de assento */
#define LIVRE       0
#define OCUPADO     1
#define PCD         2

/* Tipos de ingresso */
#define INTEIRA     1
#define MEIA        2
#define VIP         3

/* Preços base */
#define PRECO_INTEIRA 30.00
#define PRECO_MEIA    15.00
#define PRECO_VIP     50.00

int sala[FILEIRAS][COLUNAS];

/* -------------------------------------------------- */
/*  Inicializa a sala: todos livres, PCD fixos         */
/*  PCD: coluna 0 e 1 da última fileira (fileira F)    */
/* -------------------------------------------------- */
void inicializar_sala() {
    int f, c;
    for (f = 0; f < FILEIRAS; f++)
        for (c = 0; c < COLUNAS; c++)
            sala[f][c] = LIVRE;

    /* Assentos preferenciais fixos: F1, F2, F3, F4 (última fileira) */
    sala[FILEIRAS - 1][0] = PCD;
    sala[FILEIRAS - 1][1] = PCD;
    sala[FILEIRAS - 1][2] = PCD;
    sala[FILEIRAS - 1][3] = PCD;
}

/* -------------------------------------------------- */
/*  Exibe o mapa da sala                               */
/* -------------------------------------------------- */
void exibir_mapa() {
    int f, c;
    printf("\n+--------------------------------------+\n");
    printf("¦           TELA DO CINEMA             ¦\n");
    printf("+--------------------------------------+\n\n");

    printf("     ");
    for (c = 1; c <= COLUNAS; c++)
        printf(" C%d  ", c);
    printf("\n");

    for (f = 0; f < FILEIRAS; f++) {
        printf(" %c   ", 'A' + f);
        for (c = 0; c < COLUNAS; c++) {
            if (sala[f][c] == LIVRE)
                printf("[ %c%d]", 'A' + f, c + 1);
            else if (sala[f][c] == OCUPADO)
                printf("[XXX]");
            else if (sala[f][c] == PCD)
                printf("[PCD]");
        }
        printf("\n");
    }

    printf("\n Legenda:\n");
    printf("  [A1]  = Livre       [XXX] = Ocupado     [PCD] = Preferencial\n\n");
}

/* -------------------------------------------------- */
/*  Exibe resumo de disponibilidade                    */
/* -------------------------------------------------- */
void exibir_disponibilidade() {
    int f, c, livres = 0, ocupados = 0, pcd_livre = 0, pcd_ocupado = 0;

    for (f = 0; f < FILEIRAS; f++) {
        for (c = 0; c < COLUNAS; c++) {
            if (sala[f][c] == LIVRE)    livres++;
            if (sala[f][c] == OCUPADO)  ocupados++;
            if (sala[f][c] == PCD)      pcd_livre++;
        }
    }

    printf("\n--- Disponibilidade ---\n");
    printf("Assentos livres:          %d\n", livres);
    printf("Assentos ocupados:        %d\n", ocupados);
    printf("Preferenciais disponíveis:%d\n", pcd_livre);
}

/* -------------------------------------------------- */
/*  Seleciona múltiplos assentos por compra            */
/* -------------------------------------------------- */
void selecionar_assento() {
    char fileira_char;
    int  coluna, fileira, tipo, pcd_cliente;
    int  continuar, quantidade, i;
    float preco, total;

    /* Arrays para guardar resumo dos assentos escolhidos */
    int   fil_escolhida[FILEIRAS * COLUNAS];
    int   col_escolhida[FILEIRAS * COLUNAS];
    int   tipo_escolhido[FILEIRAS * COLUNAS];
    float preco_escolhido[FILEIRAS * COLUNAS];

    exibir_mapa();
    exibir_disponibilidade();

    printf("\n=== Seleção de Assentos ===\n");
    printf("Você é PCD (Pessoa com Deficiência)? (1-Sim / 0-Não): ");
    scanf("%d", &pcd_cliente);

    if (pcd_cliente) {
        printf("\nOs assentos preferenciais estão na fileira F, colunas 1 a 4.\n");
        printf("Por favor, escolha um dos assentos [PCD] no mapa acima.\n\n");
    }

    quantidade = 0;
    total      = 0;
    continuar  = 1;

    while (continuar) {

        printf("\n--- Assento %d ---\n", quantidade + 1);
        printf("Digite a fileira (A-F): ");
        scanf(" %c", &fileira_char);

        if (fileira_char >= 'a' && fileira_char <= 'z')
            fileira_char = fileira_char - 32;

        fileira = fileira_char - 'A';

        if (fileira < 0 || fileira >= FILEIRAS) {
            printf("Fileira inválida! Tente novamente.\n");
            continue;
        }

        printf("Digite o número da coluna (1-%d): ", COLUNAS);
        scanf("%d", &coluna);
        coluna--;

        if (coluna < 0 || coluna >= COLUNAS) {
            printf("Coluna inválida! Tente novamente.\n");
            continue;
        }

        if (sala[fileira][coluna] == OCUPADO) {
            printf("Esse assento já está ocupado! Escolha outro.\n");
            continue;
        }

        if (sala[fileira][coluna] == PCD && !pcd_cliente) {
            printf("Esse assento é preferencial (PCD). Reservado para pessoas com deficiência.\n");
            continue;
        }

        printf("\nTipo de ingresso:\n");
        printf("  1 - Inteira  R$ %.2f\n", PRECO_INTEIRA);
        printf("  2 - Meia     R$ %.2f\n", PRECO_MEIA);
        printf("  3 - VIP      R$ %.2f\n", PRECO_VIP);
        printf("Escolha: ");
        scanf("%d", &tipo);

        if (tipo == INTEIRA)       preco = PRECO_INTEIRA;
        else if (tipo == MEIA)     preco = PRECO_MEIA;
        else if (tipo == VIP)      preco = PRECO_VIP;
        else {
            printf("Tipo inválido! Tente novamente.\n");
            continue;
        }

        /* Reserva o assento imediatamente */
        sala[fileira][coluna] = OCUPADO;

        /* Guarda no resumo */
        fil_escolhida[quantidade]   = fileira;
        col_escolhida[quantidade]   = coluna;
        tipo_escolhido[quantidade]  = tipo;
        preco_escolhido[quantidade] = preco;
        total += preco;
        quantidade++;

        printf("? Assento %c%d reservado!\n", 'A' + fileira, coluna + 1);

        /* Mostra mapa atualizado */
        exibir_mapa();

        printf("Deseja escolher mais um assento? (1-Sim / 0-Não): ");
        scanf("%d", &continuar);
    }

    /* Resumo final da compra */
    if (quantidade > 0) {
        printf("\n+--------------------------------------+\n");
        printf("¦         RESUMO DA COMPRA             ¦\n");
        printf("¦--------------------------------------¦\n");

        for (i = 0; i < quantidade; i++) {
            char *nome_tipo;
            if (tipo_escolhido[i] == INTEIRA)     nome_tipo = "Inteira     ";
            else if (tipo_escolhido[i] == MEIA)   nome_tipo = "Meia Entrada";
            else                                   nome_tipo = "VIP         ";

            printf("¦  Assento %c%d  |  %s  |  R$ %5.2f  ¦\n",
                'A' + fil_escolhida[i],
                col_escolhida[i] + 1,
                nome_tipo,
                preco_escolhido[i]);
        }

        printf("¦--------------------------------------¦\n");
        printf("¦  Total: %d ingresso(s)   R$ %7.2f  ¦\n", quantidade, total);
        printf("+--------------------------------------+\n");
    } else {
        printf("\nNenhum assento foi selecionado.\n");
    }
}

/* -------------------------------------------------- */
/*  Menu principal                                     */
/* -------------------------------------------------- */
int main() {
    int opcao;

    setlocale(LC_ALL, "portuguese");
    inicializar_sala();

    do {
        printf("\n+------------------------------+\n");
        printf("¦   CINEMA - VENDA INGRESSOS   ¦\n");
        printf("¦------------------------------¦\n");
        printf("¦  1. Ver mapa de assentos     ¦\n");
        printf("¦  2. Selecionar assento       ¦\n");
        printf("¦  3. Ver disponibilidade      ¦\n");
        printf("¦  0. Sair                     ¦\n");
        printf("+------------------------------+\n");
        printf("Opção: ");
        scanf("%d", &opcao);

        switch (opcao) {
            case 1: exibir_mapa();            break;
            case 2: selecionar_assento();     break;
            case 3:
                exibir_mapa();
                exibir_disponibilidade();
                break;
            case 0: printf("\nSaindo... Até logo!\n"); break;
            default: printf("\nOpção inválida!\n");
        }

    } while (opcao != 0);

    return 0;
}